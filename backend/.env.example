# ── Database ────────────────────────────────────────────────────────────────
# Path to the SQLite database file (relative to project root)
DATABASE_PATH=./attendance.db

# ── Slack ────────────────────────────────────────────────────────────────────
# Bot token from your Slack app (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Channel ID or User ID to send messages to (e.g. C0XXXXXXX or U0XXXXXXX)
SLACK_CHANNEL_ID=your-channel-or-user-id

# ── Scheduler ────────────────────────────────────────────────────────────────
# node-cron expression for the daily Slack reminder (default: 7:30 AM)
REMINDER_TIME=30 7 * * *

# IANA timezone for the cron job
CRON_TIMEZONE=America/New_York

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
